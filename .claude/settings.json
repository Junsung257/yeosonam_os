{
  "permissions": {
    "allow": [
      "Bash(node -e \":*)",
      "Read(//c/Users/admin/Downloads/**)",
      "Bash(node db/batch_pexels_photos.js --force)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"c:/Users/admin/Desktop/여소남OS\" && npx tsc --noEmit 2>&1 | tail -5",
            "shell": "powershell",
            "timeout": 30,
            "statusMessage": "타입 검증 중..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cd \"c:/Users/admin/Desktop/여소남OS\" && vercel --prod 2>&1",
            "shell": "powershell",
            "timeout": 120,
            "statusMessage": "Vercel 배포 중..."
          }
        ]
      }
    ]
  }
}
