{
  "name": "yeosonam-os",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:visual": "playwright test tests/visual",
    "test:visual:update": "cross-env UPDATE_BASELINE=1 playwright test tests/visual --update-snapshots",
    "baseline:check": "node db/check_baseline_coverage.js",
    "baseline:catchup": "node db/check_baseline_coverage.js --catchup",
    "test:regression": "node tests/regression/run.js",
    "test:regression:coverage": "node tests/regression/err-coverage.js",
    "test:regression:uncovered": "node tests/regression/err-coverage.js --uncovered",
    "audit:packages": "node db/audit_existing_packages.js",
    "test:jarvis-v2": "node --test db/smoke_jarvis_v2.js",
    "audit:drift": "node db/audit_schema_drift.js",
    "audit:drift:detail": "node db/audit_schema_drift.js --detail",
    "audit:drift:ci": "node db/audit_schema_drift.js --detail --fail-on-drift",
    "audit:api-drift": "node db/audit_api_field_drift.js",
    "audit:api-drift:ci": "node db/audit_api_field_drift.js --strict"
  },
