{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable",
      "WebWorker"
    ],
    "module": "ESNext",
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "preserve",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "paths": {
      "@/*": [
        "./src/*"
      ]
    },
    "allowJs": true,
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".next-build-codex/types/**/*.ts",
    ".next-dev-3033/types/**/*.ts",
    ".next-dev-3034/types/**/*.ts",
    ".next-dev-3035/types/**/*.ts",
    ".next-dev-3036/types/**/*.ts",
    ".next-dev-3044/types/**/*.ts",
    ".next-dev-3052/types/**/*.ts",
    ".next-local-release/types/**/*.ts",
    ".next-marketing-release/types/**/*.ts",
    ".next-verify/types/**/*.ts",
    ".next/types/**/*.ts",
    "next-env.d.ts",
    ".next-dev-3037/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "db/_archive"
  ]
}
