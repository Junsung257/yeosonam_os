# ====================================================================
# Yeosonam OS production environment manifest (redacted)
# ====================================================================
# Real production secrets are managed in Vercel Environment Variables
# for the `os` project. This tracked file is only a checklist/template.
#
# Local development should use `.env.local` only. Do not paste real
# API keys, access tokens, private keys, service-role keys, JWT secrets,
# database URLs, or OAuth secrets into this file.
# ====================================================================

# Admin / auth
ADMIN_API_TOKEN=""
ADMIN_EMAILS="admin@yeosonam.com"
