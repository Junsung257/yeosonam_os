{
  "*.{ts,tsx}": [
    "eslint --fix",
    "prettier --write"
  ],
  "*.{js,jsx,mjs,cjs}": [
    "eslint --fix",
    "prettier --write"
  ],
  "*.json": [
    "prettier --write"
  ],
  "*.css": [
    "prettier --write"
  ],
  "*.md": [
    "prettier --write"
  ],
  "src/**/*.{ts,tsx}": [
    "npx tsc --noEmit --noImplicitAny"
  ]
}
