{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "incremental": true,
    "tsBuildInfoFile": ".tsbuildinfo.jarvis-readiness"
  },
  "include": [
    "next-env.d.ts",
    "src/types/**/*.d.ts",
    "src/app/api/admin/jarvis/**/*.ts",
    "src/app/api/admin/jarvis/**/*.tsx",
    "src/app/api/jarvis/**/*.ts",
    "src/app/api/agent-actions/route.ts",
    "src/app/admin/jarvis/**/*.ts",
    "src/app/admin/jarvis/**/*.tsx",
    "src/components/admin/JarvisReadinessCard.tsx",
    "src/components/admin/JarvisReadinessCard.test.tsx",
    "src/components/admin/JarvisScenarioReadinessCard.tsx",
    "src/components/admin/JarvisScenarioReadinessCard.test.tsx",
    "src/components/admin/JarvisRagStatusCard.tsx",
    "src/components/admin/JarvisRagStatusCard.test.tsx",
    "src/lib/agent-action-*.ts",
    "src/lib/agent-action-*.test.ts",
    "src/lib/free-travel/eval/**/*.ts",
    "src/lib/jarvis/**/*.ts",
    "src/lib/guardrails/prompt-injection.ts",
    "src/lib/security/prompt-injection.test.ts",
    "scripts/audit-jarvis-rag.ts",
    "scripts/eval-jarvis-golden.ts",
    "scripts/verify-free-travel-100-scenarios.ts",
    "scripts/verify-jarvis-all-scenarios.ts",
    "scripts/verify-jarvis-readiness.ts"
  ],
  "exclude": [
    "node_modules",
    ".next",
    ".next-build-codex",
    "db/_archive"
  ]
}
